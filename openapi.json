{
  "openapi": "3.1.0",
  "info": {
    "title": "G4H-RMA Quant Engine",
    "description": "Enterprise Kalman + EGARCH + MCTS Pairs Trading with Multi-Agent System",
    "version": "5.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Dashboard",
        "description": "Serve the multi-agent dashboard GUI",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/scan": {
      "post": {
        "summary": "Scan Pairs",
        "operationId": "scan_pairs_api_v1_scan_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/scan/{pair}": {
      "get": {
        "summary": "Scan Single Pair",
        "operationId": "scan_single_api_v1_scan__pair__get",
        "parameters": [
          {
            "name": "pair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Pair"
            }
          },
          {
            "name": "iterations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 5000,
              "minimum": 100,
              "default": 800,
              "title": "Iterations"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TradeSignal"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/execute": {
      "post": {
        "summary": "Execute Signal",
        "operationId": "execute_signal_api_v1_execute_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/history": {
      "get": {
        "summary": "Get History",
        "operationId": "get_history_api_v1_history_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/positions": {
      "get": {
        "summary": "Get Positions",
        "operationId": "get_positions_api_v1_positions_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/account": {
      "get": {
        "summary": "Get Account",
        "description": "Get Alpaca account information. Returns account status, cash, portfolio value, and buying power.",
        "operationId": "get_account_api_v1_account_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/theory": {
      "get": {
        "summary": "Get Theory",
        "operationId": "get_theory_api_v1_theory_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/status": {
      "get": {
        "summary": "Get Agents Status",
        "description": "Get status of all agents and the trading engine",
        "operationId": "get_agents_status_api_v1_agents_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/list": {
      "get": {
        "summary": "List Agents",
        "description": "List all registered agents",
        "operationId": "list_agents_api_v1_agents_list_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/start": {
      "post": {
        "summary": "Start Engine",
        "description": "Start the trading engine",
        "operationId": "start_engine_api_v1_agents_start_post",
        "parameters": [
          {
            "name": "auto_trade",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Auto Trade"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/stop": {
      "post": {
        "summary": "Stop Engine",
        "description": "Stop the trading engine",
        "operationId": "stop_engine_api_v1_agents_stop_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/toggle-auto-trade": {
      "post": {
        "summary": "Toggle Auto-Trade",
        "description": "Toggle auto-trading mode",
        "operationId": "toggle_auto_trade_api_v1_agents_toggle_auto_trade_post",
        "parameters": [
          {
            "name": "enable",
            "in": "query",
            "required": true,
            "schema": {
              "type": "boolean",
              "title": "Enable"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/decisions": {
      "get": {
        "summary": "Get Decisions",
        "description": "Get recent trading decisions",
        "operationId": "get_decisions_api_v1_agents_decisions_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/trades/active": {
      "get": {
        "summary": "Get Active Trades",
        "description": "Get active trades",
        "operationId": "get_active_trades_api_v1_agents_trades_active_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/consensus/{pair}": {
      "get": {
        "summary": "Get Consensus",
        "description": "Get agent consensus for a pair",
        "operationId": "get_consensus_api_v1_agents_consensus__pair__get",
        "parameters": [
          {
            "name": "pair",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Pair"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/metrics": {
      "get": {
        "summary": "Get Agent Metrics",
        "description": "Get performance metrics for all agents",
        "operationId": "get_agent_metrics_api_v1_agents_metrics_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/ws": {
      "get": {
        "summary": "WebSocket Endpoint",
        "description": "WebSocket endpoint for real-time updates",
        "operationId": "websocket_endpoint_api_v1_agents_ws_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ActionType": {
        "type": "string",
        "enum": [
          "LONG_SPREAD",
          "SHORT_SPREAD",
          "HOLD"
        ],
        "title": "ActionType"
      },
      "AssetPair": {
        "properties": {
          "base": {
            "type": "string",
            "minLength": 1,
            "title": "Base"
          },
          "quote": {
            "type": "string",
            "minLength": 1,
            "title": "Quote"
          }
        },
        "type": "object",
        "required": [
          "base",
          "quote"
        ],
        "title": "AssetPair"
      },
      "EGARCHResult": {
        "properties": {
          "annualized_vol": {
            "type": "number",
            "minimum": 0.0,
            "title": "Annualized Vol"
          },
          "forecast_vol": {
            "type": "number",
            "minimum": 0.0,
            "title": "Forecast Vol"
          },
          "leverage_gamma": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Leverage Gamma"
          },
          "regime": {
            "$ref": "#/components/schemas/VolatilityRegime"
          },
          "params": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "number"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Params"
          }
        },
        "type": "object",
        "required": [
          "annualized_vol",
          "forecast_vol",
          "regime"
        ],
        "title": "EGARCHResult"
      },
      "ExecuteRequest": {
        "properties": {
          "base": {
            "type": "string",
            "title": "Base"
          },
          "quote": {
            "type": "string",
            "title": "Quote"
          },
          "action": {
            "$ref": "#/components/schemas/ActionType"
          },
          "qty": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Qty"
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "base",
          "quote",
          "action"
        ],
        "title": "ExecuteRequest"
      },
      "ExecutionResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "action": {
            "$ref": "#/components/schemas/ActionType"
          },
          "pair": {
            "type": "string",
            "title": "Pair"
          },
          "details": {
            "type": "string",
            "title": "Details",
            "default": ""
          },
          "order_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Order Ids"
          }
        },
        "type": "object",
        "required": [
          "status",
          "action",
          "pair"
        ],
        "title": "ExecutionResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          },
          "version": {
            "type": "string",
            "title": "Version",
            "default": "5.0.0-enterprise"
          },
          "uptime_seconds": {
            "type": "number",
            "title": "Uptime Seconds",
            "default": 0.0
          },
          "modules": {
            "additionalProperties": {
              "type": "boolean"
            },
            "type": "object",
            "title": "Modules"
          }
        },
        "type": "object",
        "title": "HealthResponse"
      },
      "KalmanState": {
        "properties": {
          "beta": {
            "type": "number",
            "title": "Beta"
          },
          "alpha": {
            "type": "number",
            "title": "Alpha"
          },
          "spread": {
            "type": "number",
            "title": "Spread"
          },
          "innovation_variance": {
            "type": "number",
            "title": "Innovation Variance"
          },
          "pure_z_score": {
            "type": "number",
            "title": "Pure Z Score"
          }
        },
        "type": "object",
        "required": [
          "beta",
          "alpha",
          "spread",
          "innovation_variance",
          "pure_z_score"
        ],
        "title": "KalmanState"
      },
      "MCTSResult": {
        "properties": {
          "action": {
            "$ref": "#/components/schemas/ActionType"
          },
          "expected_value": {
            "type": "number",
            "title": "Expected Value"
          },
          "visit_distribution": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Visit Distribution"
          },
          "avg_reward_distribution": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Avg Reward Distribution"
          }
        },
        "type": "object",
        "required": [
          "action",
          "expected_value"
        ],
        "title": "MCTSResult"
      },
      "ScanRequest": {
        "properties": {
          "pairs": {
            "items": {
              "$ref": "#/components/schemas/AssetPair"
            },
            "type": "array",
            "maxItems": 20,
            "minItems": 1,
            "title": "Pairs"
          },
          "mcts_iterations": {
            "type": "integer",
            "maximum": 5000.0,
            "minimum": 100.0,
            "title": "Mcts Iterations",
            "default": 800
          },
          "source": {
            "$ref": "#/components/schemas/SignalSource",
            "default": "KALMAN_MCTS"
          }
        },
        "type": "object",
        "required": [
          "pairs"
        ],
        "title": "ScanRequest"
      },
      "ScanResponse": {
        "properties": {
          "scan_id": {
            "type": "string",
            "title": "Scan Id"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "signals": {
            "items": {
              "$ref": "#/components/schemas/TradeSignal"
            },
            "type": "array",
            "title": "Signals"
          },
          "errors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Errors"
          }
        },
        "type": "object",
        "required": [
          "scan_id",
          "signals"
        ],
        "title": "ScanResponse"
      },
      "SignalSource": {
        "type": "string",
        "enum": [
          "KALMAN_MCTS",
          "COINTEGRATION",
          "BACKTEST"
        ],
        "title": "SignalSource"
      },
      "TradeSignal": {
        "properties": {
          "pair": {
            "type": "string",
            "title": "Pair"
          },
          "action": {
            "$ref": "#/components/schemas/ActionType"
          },
          "confidence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence"
          },
          "kalman": {
            "$ref": "#/components/schemas/KalmanState"
          },
          "egarch": {
            "$ref": "#/components/schemas/EGARCHResult"
          },
          "mcts": {
            "$ref": "#/components/schemas/MCTSResult"
          },
          "source": {
            "$ref": "#/components/schemas/SignalSource"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "reasoning": {
            "type": "string",
            "title": "Reasoning",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "pair",
          "action",
          "confidence",
          "kalman",
          "egarch",
          "mcts",
          "source"
        ],
        "title": "TradeSignal"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VolatilityRegime": {
        "type": "string",
        "enum": [
          "LOW",
          "NORMAL",
          "ELEVATED",
          "CRISIS"
        ],
        "title": "VolatilityRegime"
      }
    }
  }
}
