# =============================================
# G4H-RMA Quant Engine V5.0 — Environment Configuration
# =============================================
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control!
# =============================================

# ─────────────────────────────────────────────
# Alpaca Trading API (Paper Trading)
# ─────────────────────────────────────────────
# Get your keys from: https://app.alpaca.markets/paper
# 
# 1. Sign up / Log in
# 2. Go to "Paper Trading" section
# 3. Click "View Keys"
# 4. Copy API Key ID and Secret Key
# ─────────────────────────────────────────────

APCA_API_KEY_ID=PKXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
APCA_API_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# For live trading (NOT RECOMMENDED for testing!)
# APCA_API_BASE_URL=https://api.alpaca.markets


# ─────────────────────────────────────────────
# Optional: CCXT Exchange Settings
# ─────────────────────────────────────────────
# For crypto trading via CCXT

# CCXT_EXCHANGE=binance
# CCXT_RATE_LIMIT=true


# ─────────────────────────────────────────────
# Optional: Trading Configuration
# ─────────────────────────────────────────────

# Default quantity for base asset in pairs
# DEFAULT_QTY_BASE=10

# Maximum position notional (risk limit)
# MAX_POSITION_NOTIONAL=25000

# Daily trade limit
# MAX_DAILY_TRADES=10


# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────

# API server host
# API_HOST=0.0.0.0

# API server port
# API_PORT=8000

# Number of worker processes
# API_WORKERS=1


# ─────────────────────────────────────────────
# Security Notes
# ─────────────────────────────────────────────
# 
# ✓ This file (.env) is in .gitignore — never committed
# ✓ Keep your API keys secret
# ✓ Use paper trading for testing
# ✓ Never share your .env file
# 
# If keys are exposed:
# 1. Delete them in Alpaca dashboard immediately
# 2. Generate new keys
# 3. Update .env
# ─────────────────────────────────────────────
